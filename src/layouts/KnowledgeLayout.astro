---
import BaseLayout from "./BaseLayout.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils.ts";
import { textbooks } from "../data/textbooks.ts";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const textbookLabels = t("textbooks") as unknown as Record<string, string>;
const siteTitle = String(t("siteTitle"));
const platformTagline = String(t("platformTagline"));

const localePrefix = `/${lang}`;
interface Props {
  title?: string;
  currentTextbook?: string;
}

const { title, currentTextbook } = Astro.props;
---

<BaseLayout title={title}>
  <div class="layout">
    <aside class="sidebar">
      <div class="sidebar-header">
        <a href={localePrefix} class="logo">{siteTitle}</a>
        <p class="tagline">{platformTagline}</p>
      </div>
      <nav class="sidebar-nav">
        {
          textbooks.map((tb) => (
            <a
              href={`${localePrefix}/${tb}/`}
              class:list={["nav-item", { active: currentTextbook === tb }]}
            >
              {textbookLabels[tb]}
            </a>
          ))
        }
      </nav>
    </aside>
    <main class="content">
      <div class="content-surface">
        <slot />
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  .layout {
    display: flex;
    min-height: 100vh;
    width: min(1380px, calc(100% - 32px));
    margin: 16px auto;
    border: 1px solid color-mix(in srgb, var(--line) 65%, transparent);
    border-radius: 22px;
    background: color-mix(in srgb, var(--panel) 75%, #edf2ff 25%);
    backdrop-filter: blur(8px);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
  }
  .sidebar {
    width: 292px;
    border-right: 1px solid color-mix(in srgb, var(--line) 70%, transparent);
    padding: 22px 16px;
    position: sticky;
    top: 0;
    height: calc(100vh - 32px);
    overflow-y: auto;
    background: linear-gradient(180deg, #f8fbff, #f2f6ff);
  }
  .sidebar-header {
    margin-bottom: 18px;
    padding: 8px 10px 12px;
    border-bottom: 0;
  }
  .logo {
    display: inline-block;
    font-size: 1.35rem;
    font-weight: 700;
    text-decoration: none;
    color: var(--brand-strong);
    margin-bottom: 4px;
  }
  .tagline {
    font-size: 0.78rem;
    color: var(--text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .nav-item {
    display: block;
    padding: 10px 12px;
    border-radius: 10px;
    border: 1px solid transparent;
    text-decoration: none;
    color: var(--text);
    font-size: 0.92rem;
    transition:
      background-color 0.2s,
      border-color 0.2s,
      transform 0.2s;
  }
  .nav-item:hover {
    background-color: #f7f9ff;
    border-color: #dae3ff;
    transform: translateX(2px);
  }
  .nav-item.active {
    background: linear-gradient(135deg, #eaf0ff, #eefcf8);
    border-color: #bfcfff;
    color: var(--brand-strong);
    font-weight: 600;
  }
  .content {
    flex: 1;
    padding: 24px;
    min-width: 0;
  }
  .content-surface {
    max-width: 980px;
    background: var(--panel);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    padding: 30px;
  }

  @media (max-width: 1080px) {
    .layout {
      width: calc(100% - 20px);
      margin: 10px auto;
    }
    .sidebar {
      width: 245px;
    }
    .content-surface {
      padding: 22px;
    }
  }

  @media (max-width: 860px) {
    .layout {
      display: block;
    }
    .sidebar {
      position: static;
      width: 100%;
      height: auto;
      padding: 14px;
      border-right: 0;
      border-bottom: 1px solid var(--line);
    }
    .sidebar-nav {
      overflow-x: auto;
      display: grid;
      grid-template-columns: repeat(7, minmax(160px, 1fr));
    }
    .content {
      padding: 0;
    }
    .content-surface {
      max-width: 100%;
      width: 100%;
      padding: 18px;
      border-radius: 0;
      box-shadow: none;
    }
  }
</style>
